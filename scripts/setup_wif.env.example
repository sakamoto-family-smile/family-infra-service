# ============================================================
# Workload Identity Federation セットアップ設定
# このファイルを scripts/setup_wif.env にコピーして値を設定してください
#   cp scripts/setup_wif.env.example scripts/setup_wif.env
# setup_wif.env は .gitignore により管理対象外です
# ============================================================

# GitHub
GITHUB_ORG="sakamoto-family-smile"
GITHUB_REPO="family-infra-service"

# GCPプロジェクトID（カンマ区切りで prod, dev の順に指定）
GCP_PROJECTS="youyaku-ai,youyaku-ai-dev"

# GitHub Environment名（GCP_PROJECTSと同じ順序で指定）
GITHUB_ENVS="prod,dev"

# WIF リソース名
POOL_ID="github-actions-pool"
PROVIDER_ID="github-actions-provider"

# サービスアカウント名
SA_NAME="github-actions-sa"
