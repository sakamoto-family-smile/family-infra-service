# Application
ENV=dev
DEBUG=false

# GCP (required — no default value)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# CORS (comma-separated list for production)
ALLOWED_ORIGINS=https://your-app.example.com

# Cloud SQL
CLOUD_SQL_INSTANCE=youyaku-ai-dev:asia-northeast1:family-app-db
DB_NAME=family_app
DB_USER=family_app
DB_PASSWORD=your_password_here

# Firebase
FIREBASE_PROJECT_ID=youyaku-ai-dev
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # local only

# Cloud Storage
GCS_BUCKET=family-app-media-dev

# Cloud Tasks
CLOUD_TASKS_QUEUE=family-app-tasks
CLOUD_TASKS_LOCATION=asia-northeast1
CLOUD_RUN_SERVICE_URL=https://family-app-api-xxxxxxxxxx-an.a.run.app
